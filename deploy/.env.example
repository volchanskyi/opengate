# ---- Required ----

# JWT signing secret for authentication (min 32 chars recommended)
JWT_SECRET=changeme

# PostgreSQL password for the opengate database user
POSTGRES_PASSWORD=changeme

# ---- Server credentials ----

# Intel AMT WSMAN credentials for device management
AMT_USER=admin
AMT_PASS=

# VAPID contact email for Web Push notifications (RFC 8292)
VAPID_CONTACT=

# GitHub repo for auto-syncing agent manifests from releases (owner/repo)
OPENGATE_GITHUB_REPO=volchanskyi/opengate

# Public base URL for install script (auto-detected from request headers if unset)
OPENGATE_BASE_URL=

# QUIC hostname for agent connections (bypasses CDN proxy, e.g. quic.opengate.example.com)
OPENGATE_QUIC_HOST=

# Log level for structured logging (info or debug)
LOG_LEVEL=info

# ---- Staging ----

# JWT secret for persistent staging environment (from GitHub environment secrets)
STAGING_JWT_SECRET=changeme

# PostgreSQL password for staging (separate from production)
STAGING_POSTGRES_PASSWORD=changeme

# ---- Deployment ----

# Container image tag (sha-abc1234 or latest)
IMAGE_TAG=latest

# Domain for Caddy auto-TLS (Let's Encrypt)
DOMAIN=opengate.example.com
