{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "Workflow",
      "url": "https://github.com/volchanskyi/opengate/actions/workflows/benchmark.yml",
      "targetBlank": true,
      "type": "link"
    }
  ],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "description": "Latest benchmark allocation count. This is part of the deterministic regression gate because allocs/op is stable across shared-runner CPU load.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "allocs/op",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "always",
            "spanNulls": false
          },
          "unit": "none",
          "min": 0
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "title": "allocs/op (gated)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
          "expr": "benchmark_allocs_op{env=\"ci\"}",
          "legendFormat": "{{lang}}/{{benchmark}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "description": "Latest bytes allocated per operation. This is part of the deterministic regression gate.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "B/op",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "always",
            "spanNulls": false
          },
          "unit": "bytes",
          "min": 0
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "title": "B/op (gated)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
          "expr": "benchmark_bytes_op{env=\"ci\"}",
          "legendFormat": "{{lang}}/{{benchmark}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "description": "Wall-clock benchmark time. This is advisory only because shared GitHub runners can produce noisy CPU timing.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "ns/op",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "always",
            "spanNulls": false
          },
          "unit": "ns",
          "min": 0
        }
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 9 },
      "id": 3,
      "options": {
        "legend": { "calcs": ["lastNotNull", "min", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "title": "ns/op (advisory)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
          "expr": "benchmark_ns_op{env=\"ci\"}",
          "legendFormat": "{{lang}}/{{benchmark}}",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["benchmarks", "ci", "victoriametrics"],
  "templating": { "list": [] },
  "time": { "from": "now-30d", "to": "now" },
  "timepicker": {},
  "timezone": "utc",
  "title": "Benchmark Trends",
  "uid": "opengate-benchmark-trend",
  "version": 1
}
