    {
      "title": "ADR-017 — Loki is the canonical trend store",
      "url": "https://github.com/volchanskyi/opengate/blob/main/docs/adr/ADR-017-ci-gates-consolidation.md",
      "targetBlank": true,
      "type": "link"
    }
  ],
  "panels": [
    {
      "datasource": { "type": "loki", "uid": "Loki" },
      "description": "Latest mutation score for each language. Source: Loki log lines from the nightly `mutation.yml` workflow.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 65 },
              { "color": "yellow", "value": 70 },
              { "color": "green", "value": 75 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "title": "Latest mutation score",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "Loki" },
          "expr": "last_over_time({job=\"mutation-testing\"} | json | unwrap score_pct [30d])",
          "queryType": "instant",
          "legendFormat": "{{ language }}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "Loki" },
      "description": "Rolling mutation score per language. Score = (killed + timeout) / (killed + survived + timeout + no_coverage). Per-language thresholds and the regression-alert rules are documented in [docs/Testing.md].",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "score %",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "always",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "percent",
          "min": 50,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 70 }
            ]
          }
        }
      },
      "gridPos": { "h": 10, "w": 16, "x": 8, "y": 0 },
      "id": 2,
      "options": {
        "legend": { "calcs": ["min", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "title": "Mutation score over time (Rust / Go / Web)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "Loki" },
          "expr": "last_over_time({job=\"mutation-testing\"} | json | unwrap score_pct [1d])",
          "queryType": "range",
          "legendFormat": "{{ language }}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "Loki" },
      "description": "Survived (LIVED) mutant count per language over time. A rising line means new untested code paths are accumulating.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisBorderShow": false, "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "pointSize": 5, "showPoints": "always", "spanNulls": false }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 3,
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "title": "Surviving mutants per language",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "Loki" },
          "expr": "last_over_time({job=\"mutation-testing\"} | json | unwrap survived [1d])",
          "queryType": "range",
          "legendFormat": "{{ language }}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "Loki" },
      "description": "No-coverage mutant count per language over time. Distinct from survived — these mutants were never even exercised by a test. Rising line = test gaps growing.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisBorderShow": false, "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "pointSize": 5, "showPoints": "always", "spanNulls": false }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 4,
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "title": "No-coverage mutants per language",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "Loki" },
          "expr": "last_over_time({job=\"mutation-testing\"} | json | unwrap no_coverage [1d])",
          "queryType": "range",
          "legendFormat": "{{ language }}",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["mutation", "testing", "quality"],
  "templating": { "list": [] },
  "time": { "from": "now-30d", "to": "now" },
