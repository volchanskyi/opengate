{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "Workflow",
      "url": "https://github.com/volchanskyi/opengate/actions/workflows/terraform-drift.yml",
      "targetBlank": true,
      "type": "link"
    },
    {
      "title": "Monitoring docs",
      "url": "https://github.com/volchanskyi/opengate/blob/main/docs/Monitoring.md",
      "targetBlank": true,
      "type": "link"
    }
  ],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "description": "Latest refresh-only terraform drift count from the nightly `terraform-drift.yml` workflow. Zero means the refresh-only plan found no out-of-band drift.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "none",
          "min": 0
        }
      },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value"
      },
      "title": "Latest drift count",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
          "expr": "last_over_time(terraform_drift_count{env=\"ci\"}[30d])",
          "legendFormat": "drift count",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "description": "Refresh-only drift count over time. The workflow still fails red and sends Telegram only when drift is detected; this panel adds the successful zero-drift samples.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "resources",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "always",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "none",
          "min": 0
        }
      },
      "gridPos": { "h": 10, "w": 16, "x": 8, "y": 0 },
      "id": 2,
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "title": "Drift count over time",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
          "expr": "last_over_time(terraform_drift_count{env=\"ci\"}[1d])",
          "legendFormat": "drift count",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "description": "Drifted resource counts grouped by terraform action and resource type. This emits only when a drifted resource exists.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "resources",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "always",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "none",
          "min": 0
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 10 },
      "id": 3,
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "title": "Drifted resources by action/type",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
          "expr": "sum by (action, type) (last_over_time(terraform_drift_resources{env=\"ci\"}[1d]))",
          "legendFormat": "{{action}}/{{type}}",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["terraform", "drift", "ci-trends"],
  "templating": { "list": [] },
  "time": { "from": "now-30d", "to": "now" },
  "timepicker": {},
  "timezone": "utc",
  "title": "Terraform Drift Trend",
  "uid": "opengate-terraform-drift-trend",
  "version": 1
}
