# Terraform state — contains resource attributes including sensitive data
*.tfstate
*.tfstate.backup
.terraform/

# Variable files — contain credentials, OCIDs, operator IPs
terraform.tfvars
*.auto.tfvars
override.tf
override.tf.json

# Backend config — contains operator-specific OCI namespace in the S3 endpoint
# and the path to S3-compat credentials. backend.tfbackend.example is committed.
backend.tfbackend

# Plan files may contain interpolated secret values
tfplan
*.tfplan

# Crash logs may contain sensitive provider output
crash.log
crash.*.log
