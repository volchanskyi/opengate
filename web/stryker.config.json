{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_comment": "Mutation testing config for the web client. Threshold gate is deferred until PR 9.",
  "packageManager": "npm",
  "testRunner": "vitest",
  "checkers": ["typescript"],
  "tsconfigFile": "tsconfig.json",
  "coverageAnalysis": "perTest",
  "ignoreStatic": true,
  "thresholds": {
    "high": 80,
    "low": 65,
    "break": null
  },
  "mutate": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!src/**/*.spec.ts",
    "!src/**/*.spec.tsx",
    "!src/**/__tests__/**",
    "!src/types/api.d.ts",
    "!src/types/**/*.d.ts",
    "!src/main.tsx",
    "!src/router.tsx",
    "!src/features/terminal/use-terminal.ts",
    "!src/features/remote-desktop/use-remote-desktop.ts",
    "!src/features/remote-desktop/input-handler.ts",
    "!src/state/connection-store.ts"
  ],
  "reporters": ["html", "clear-text", "progress", "json"],
  "htmlReporter": {
    "fileName": "reports/mutation/mutation.html"
  },
  "jsonReporter": {
    "fileName": "reports/mutation/mutation.json"
  }
}
